{
  "name": "snail-job",
  "type": "module",
  "version": "1.8.0",
  "description": "A flexible, reliable, and fast platform for distributed task retry and distributed task scheduling.",
  "license": "Apache-2.0",
  "homepage": "https://gitee.com/aizuda/snail-job",
  "repository": {
    "githubUrl": "https://github.com/aizuda/snail-job.git",
    "giteeUrl": "https://gitee.com/aizuda/snail-job.git"
  },
  "bugs": {
    "url": "https://gitee.com/aizuda/snail-job/issues"
  },
  "keywords": [
    "Job",
    "Retry",
    "Snail Job",
    "Vue3 admin ",
    "vue-admin-template",
    "Vite7",
    "TypeScript",
    "naive-ui",
    "naive-ui-admin",
    "ant-design-vue v4",
    "UnoCSS"
  ],
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.5.0"
  },
  "scripts": {
    "build": "vite build --mode prod",
    "build:test": "vite build --mode test",
    "cleanup": "sa cleanup",
    "commit": "sa git-commit",
    "commit:zh": "sa git-commit -l=zh-cn",
    "dev": "vite --mode test",
    "dev:prod": "vite --mode prod",
    "gen-route": "sa gen-route",
    "lint": "eslint . --fix",
    "prepare": "simple-git-hooks",
    "preview": "vite preview",
    "release": "sa release",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "update-pkg": "sa update-pkg"
  },
  "dependencies": {
    "@better-scroll/core": "2.5.1",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@iconify/vue": "5.0.0",
    "@sa/axios": "workspace:*",
    "@sa/color": "workspace:*",
    "@sa/cron-input": "workspace:*",
    "@sa/hooks": "workspace:*",
    "@sa/materials": "workspace:*",
    "@sa/utils": "workspace:*",
    "@vueuse/core": "13.5.0",
    "clipboard": "2.0.11",
    "dayjs": "1.11.13",
    "defu": "6.1.4",
    "echarts": "5.5.1",
    "highlight.js": "^11.10.0",
    "json5": "2.2.3",
    "naive-ui": "2.42.0",
    "nprogress": "0.2.0",
    "pinia": "3.0.3",
    "tailwind-merge": "3.0.1",
    "ts-md5": "1.3.1",
    "vue": "3.5.17",
    "vue-codemirror6": "^1.3.4",
    "vue-drag-resize": "^1.5.4",
    "vue-draggable-plus": "0.6.0",
    "vue-i18n": "11.1.9",
    "vue-router": "4.5.1",
    "vue3-puzzle-vcode": "^1.1.7"
  },
  "devDependencies": {
    "@elegant-router/vue": "0.3.8",
    "@iconify/json": "2.2.357",
    "@sa/scripts": "workspace:*",
    "@sa/uno-preset": "workspace:*",
    "@soybeanjs/eslint-config": "1.7.1",
    "@types/node": "24.0.13",
    "@types/nprogress": "0.2.3",
    "@unocss/eslint-config": "66.3.3",
    "@unocss/preset-icons": "66.3.3",
    "@unocss/preset-uno": "66.3.3",
    "@unocss/transformer-directives": "66.3.3",
    "@unocss/transformer-variant-group": "66.3.3",
    "@unocss/vite": "66.3.3",
    "@vitejs/plugin-vue": "6.0.0",
    "@vitejs/plugin-vue-jsx": "5.0.1",
    "consola": "3.4.2",
    "eslint": "9.31.0",
    "eslint-plugin-vue": "10.3.0",
    "kolorist": "1.8.0",
    "sass": "1.89.2",
    "simple-git-hooks": "2.13.0",
    "tsx": "4.20.3",
    "typescript": "5.8.3",
    "unplugin-icons": "22.1.0",
    "unplugin-vue-components": "28.8.0",
    "vite": "7.0.4",
    "vite-plugin-progress": "0.0.7",
    "vite-plugin-svg-icons": "2.0.1",
    "vite-plugin-vue-devtools": "7.7.7",
    "vue-eslint-parser": "10.2.0",
    "vue-tsc": "3.0.1"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm sa git-commit-verify",
    "pre-commit": "pnpm typecheck && pnpm lint && git diff --exit-code"
  },
  "officialWebsite": "https://snailjob.opensnail.com",
  "website": "https://snailjob.opensnail.com/docs/preview.html"
}
